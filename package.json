{
  "name": "copperhead-hub-20",
  "version": "0.18.2",
  "private": true,
  "type": "module",
  "description": "Copperhead \u2014 ICJIA Research Hub 2.0 public frontend (Nuxt 4, Nuxt UI 4, static generation)",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate && node scripts/postgenerate.mjs && node scripts/build-sitemap.mjs && pnpm pagefind",
    "generate:full": "nuxt generate && node scripts/postgenerate.mjs && node scripts/build-doc-stubs.mjs && node scripts/build-sitemap.mjs && pnpm pagefind",
    "pagefind": "pagefind --site .output/public/researchhub",
    "parity": "node scripts/parity-check.mjs",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "typecheck": "nuxt typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:a11y": "playwright test",
    "lhci": "lhci autorun"
  },
  "dependencies": {
    "@nuxt/image": "2.0.0",
    "@nuxt/ui": "^4.9.0",
    "isomorphic-dompurify": "3.18.0",
    "marked": "18.0.6",
    "marked-footnote": "1.4.0",
    "nuxt": "~4.4.8",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@icjia/pdf-search-index": "1.4.1",
    "@iconify-json/lucide": "^1.2.116",
    "@lhci/cli": "^0.15.1",
    "@nuxt/eslint": "^1.16.0",
    "@playwright/test": "^1.61.1",
    "eslint": "^10.7.0",
    "http-server": "^14.1.1",
    "pagefind": "1.5.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@tailwindcss/oxide",
      "esbuild",
      "sharp",
      "unrs-resolver",
      "vue-demi"
    ]
  },
  "packageManager": "pnpm@10.33.4"
}
